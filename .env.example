# Your domain pointing to this server's IP
DOMAIN=

# Leave empty to disable auth (use Caddy IP allowlist instead)
MCP_API_KEY=

# NordVPN access token for the bundled nordlynx-proxy sidecar container.
# Get it from https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
# (click "Get Access token"). Required if you want proxy fallback enabled.
NORDVPN_TOKEN=

# NordVPN country for the WireGuard tunnel (default: Germany).
NORDVPN_COUNTRY=Germany

# SOCKS5 proxy fallback for bypassing datacenter IP blocks.
# Used as a fallback when direct requests fail or return non-200 status.
# Use socks5h:// (not socks5://) to delegate DNS resolution to the proxy.
# Default points at the bundled nordlynx-proxy sidecar container:
PROXY_URL=socks5h://kari-nordlynx:1080
# Alternative: direct NordVPN remote endpoint (now typically blocked from datacenter IPs):
# PROXY_URL=socks5h://user:pass@amsterdam.nl.socks.nordhold.net:1080
