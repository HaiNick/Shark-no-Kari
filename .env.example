# Your domain pointing to this server's IP
DOMAIN=

# Leave empty to disable auth (use Caddy IP allowlist instead).
# Cannot be set at the same time as OIDC_ENABLED=true.
MCP_API_KEY=

# NordVPN access token for the bundled nordlynx-proxy sidecar container.
# Get it from https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
# (click "Get Access token"). Required if you want proxy fallback enabled.
NORDVPN_TOKEN=

# NordVPN country for the WireGuard tunnel (default: Germany).
NORDVPN_COUNTRY=Germany

# SOCKS5 proxy fallback for bypassing datacenter IP blocks.
# Used as a fallback when direct requests fail or return non-200 status.
# Use socks5h:// (not socks5://) to delegate DNS resolution to the proxy.
# Default points at the bundled nordlynx-proxy sidecar container:
PROXY_URL=socks5h://kari-nordlynx:1080
# Alternative: direct NordVPN remote endpoint (now typically blocked from datacenter IPs):
# PROXY_URL=socks5h://user:pass@amsterdam.nl.socks.nordhold.net:1080

# --------------------------------------------------------------------------- #
# OIDC / OAuth 2.1 (optional, opt-in)
# --------------------------------------------------------------------------- #
# When enabled, MCP_API_KEY MUST be empty. Set OIDC_ENABLED=true to activate.
# On first connect Claude opens a browser tab for consent at your Pocket ID.
OIDC_ENABLED=false

# Full URL to your OIDC provider's discovery document.
OIDC_CONFIG_URL=https://id.snowy-burbot.com/.well-known/openid-configuration

# Client credentials from your Pocket ID application (see README for setup).
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Public base URL of this MCP server (used for redirect URIs and metadata).
OIDC_BASE_URL=https://kari.snowy-burbot.com

# Secret key used by fastmcp to sign its own JWTs issued to MCP clients.
# Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=

# Fernet key for encrypting the OAuth client registration store on disk.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=
